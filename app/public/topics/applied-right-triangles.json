      "id": "trig-001",
      "statement": "Un pal d'una bandera de 8 m de longitud està recolzat formant un angle de 60° amb el terra. A quina alçada arriba l'extrem superior del pal?",
      "graphic": {
        "kind": "applied-triangle",
        "angleDeg": 60.0,
        "labels": {
          "hypotenuse": "8 m",
          "opposite": "?",
          "angle": "60°"
        },
        "highlight": [
          "opposite"
        ],
        "vertexLabels": {
          "acuteAngle": "terra",
          "top": "extrem"
        }
      },
      "options": [
        "$4\\ \\text{m}$",
        "$6.93\\ \\text{m}$",
        "$13.86\\ \\text{m}$",
        "$9.24\\ \\text{m}$"
      ],
      "correct": 1,
      "resolution": [
        {
          "kind": "text",
          "text": "La hipotenusa és el pal (8 m) i l'alçada és el catet oposat a l'angle de 60°."
        },
        {
          "kind": "math",
          "tex": "\\sin(60°) = \\dfrac{\\text{alçada}}{\\text{pal}}"
